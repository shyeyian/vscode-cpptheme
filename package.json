{
    "name": "cpptheme",
    "displayName": "cpptheme",
    "description": "cpptheme",
    "icon": "share/package.png",
    "publisher": "shyeyian",
    "version": "1.1.112",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Language Packs",
        "Keymaps",
        "Themes"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/shyeyian/vscode-cpptheme"
    },
    "main": "contribute/keybinding/rewrite.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "commands": {
            "command": "rewriteUserKeybindings",
            "title": "%rewriteUserKeybindings%",
            "category": "Preferences"
        },
        "grammars": [
            {
                "scopeName": "module.injection",
                "injectTo": [
                    "source.cpp"
                ],
                "path": "contribute/grammar/module.json"
            },
            {
                "scopeName": "noexcept.injection",
                "injectTo": [
                    "source.cpp"
                ],
                "path": "contribute/grammar/noexcept.json"
            },
            {
                "scopeName": "preprocessor.injection",
                "injectTo": [
                    "source.cpp"
                ],
                "path": "contribute/grammar/preprocessor.json"
            },
            {
                "scopeName": "punctuation.injection",
                "injectTo": [
                    "source.cpp"
                ],
                "path": "contribute/grammar/punctuation.json"
            }
        ],
        "localizations": [
            {
                "languageId": "zh-cn",
                "languageName": "Chinese Simplified",
                "localizedLanguageName": "中文(简体)",
                "translations": [
                    {
                        "id": "vscode",
                        "path": "contribute/localization/main.i18n.json"
                    },
                    {
                        "id": "vscode.git",
                        "path": "contribute/localization/extensions/vscode.git.i18n.json"
                    },
                    {
                        "id": "vscode.references-view",
                        "path": "contribute/localization/extensions/vscode.references-view.i18n.json"
                    }
                ]
            }
        ],
        "productIconThemes": [
            {
                "label": "cpptheme-icon",
                "id": "cpptheme-icon",
                "path": "contribute/product-icon-theme/cpptheme-icon.json"
            }
        ],
        "themes": [
            {
                "label": "cpptheme-dark",
                "uiTheme": "vs-dark",
                "path": "contribute/theme/cpptheme-dark.json"
            },
            {
                "label": "cpptheme-light",
                "uiTheme": "vs",
                "path": "contribute/theme/cpptheme-light.json"
            }
        ]
    }
}
