{
    "scopeName": "module.injection",
    "injectionSelector": "L:source.cpp & -comment & -string",
    "patterns": [
        {
            "match": "^\\s*((?:export\\s+)?module|(?:export\\s+)?import)\\s+([\\w\\.\\s:]*)\\s*(;)\\s*$",
            "captures": {
                "1": {
                    "patterns": [
                        {
                            "match": "export",
                            "name": "keyword.other.export.cpp"
                        },
                        {
                            "match": "import",
                            "name": "keyword.other.import.cpp"
                        },
                        {
                            "match": "module",
                            "name": "keyword.other.module.cpp"
                        }
                    ]
                },
                "2": {
                    "patterns": [
                        {
                            "match": "\\w+",
                            "name": "entity.name.module.cpp"
                        },
                        {
                            "match": "[\\.:]",
                            "name": "punctuation.separator.module.cpp"
                        }
                    ]
                },
                "3": {
                    "patterns": [
                        {
                            "match": ";",
                            "name": "punctuation.terminator.module.cpp"
                        }
                    ]
                }
            }
        },
        {
            "match": "^\\s*(module)\\s*(;)\\s*$",
            "captures": {
                "1": {
                    "patterns": [
                        {
                            "match": "module",
                            "name": "keyword.other.module.cpp"
                        }
                    ]
                },
                "2": {
                    "patterns": [
                        {
                            "match": ";",
                            "name": "punctuation.terminator.module.cpp"
                        }
                    ]
                }
            }
        }
    ]
}